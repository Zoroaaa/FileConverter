# 本地开发环境变量示例
# 复制为 .dev.vars 并填入真实值

# Gotenberg 服务地址（本地开发可用 Docker 启动）
# docker run --rm -p 3000:3000 gotenberg/gotenberg:8
GOTENBERG_URL=http://localhost:3000

# Adobe PDF Services（可选，用于 PDF → Word/Excel/PPT）
# 免费注册：https://developer.adobe.com/document-services/
ADOBE_CLIENT_ID=your_adobe_client_id_here
ADOBE_CLIENT_SECRET=your_adobe_client_secret_here
